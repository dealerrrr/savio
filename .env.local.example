# Copiá este archivo a .env.local y completá con tu clave real.
# .env.local NUNCA se sube al repo (ver .gitignore).
GEMINI_API_KEY=

# Formulario de /entrevista/ (envío de email vía Resend).
# El dominio del remitente (RESEND_FROM) tiene que estar verificado en Resend.
RESEND_API_KEY=
RESEND_FROM=Logia Savio <formulario@lasavio.com.ar>
CONTACTO_EMAIL=info@lasavio.com.ar

# Registro anónimo de conversaciones con el Guardián (Upstash Redis, REST).
# Sacá URL y token del panel de Upstash (REST API de la base creada).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
